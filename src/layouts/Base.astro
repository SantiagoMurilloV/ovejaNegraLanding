---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.shortDesc,
  ogImage = "/og.jpg",
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://ovejanegra.studio");
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageAbsolute = new URL(ogImage, siteOrigin).toString();
---

<!doctype html>
<html lang="es" class="grain">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#07060a" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-192.png" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Oveja Negra" />
    <link rel="mask-icon" href="/favicon.svg" color="#c9a35b" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Oveja Negra Gentleman Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:secure_url" content={ogImageAbsolute} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Oveja Negra Gentleman Studio — Armenia, Quindío" />
    <meta property="og:locale" content="es_CO" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Local Business -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BarberShop",
      "name": site.name,
      "image": "https://ovejanegra.studio/og.jpg",
      "url": "https://ovejanegra.studio",
      "telephone": site.whatsapp,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.address,
        "addressLocality": "Armenia",
        "addressRegion": "Quindío",
        "addressCountry": "CO"
      },
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "999"
      }
    })} />

    <ClientRouter />
  </head>
  <body class="antialiased">
    <slot />

    <!-- Reveal-on-scroll + parallax -->
    <script>
      // Si el usuario tiene "Reducir movimiento" en iOS/macOS, mostramos todo
      // sin animación pero al menos visible. Sin esto, los elementos quedaban
      // ocultos para usuarios con preferencia accesible.
      const prefersReduce = () =>
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const showAllImmediate = () => {
        document.querySelectorAll("[data-reveal]").forEach((el) => {
          el.classList.add("is-visible");
        });
      };

      const isInViewport = (el: Element) => {
        const r = el.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        return r.top < vh && r.bottom > 0;
      };

      const init = () => {
        // Si reduce-motion: pinta todo visible y salimos.
        if (prefersReduce()) {
          showAllImmediate();
          return;
        }

        const els = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal]"));

        // ─── PRIMER VIEWPORT: animación garantizada con stagger ─────
        // En iOS Safari, IntersectionObserver puede dispararse antes
        // del primer paint y el browser optimiza saltándose la transición.
        // Para los elementos ya visibles al cargar, los activamos con
        // setTimeout escalonado — animación 100% confiable.
        const STAGGER_MS = 110;
        const firstWave = els.filter(isInViewport);
        const offscreen = els.filter((el) => !isInViewport(el));

        firstWave.forEach((el, i) => {
          setTimeout(() => {
            el.classList.add("is-visible");
          }, 80 + i * STAGGER_MS); // 80ms inicial para asegurar primer paint
        });

        // ─── REVEALS POR SCROLL: observer para los que están abajo ──
        if (!("IntersectionObserver" in window)) {
          // Fallback: si no hay observer, muéstralos todos al instante
          offscreen.forEach((el) => el.classList.add("is-visible"));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  const el = e.target as HTMLElement;
                  requestAnimationFrame(() => el.classList.add("is-visible"));
                  io.unobserve(el);
                }
              });
            },
            { threshold: 0.05, rootMargin: "0px 0px -8% 0px" }
          );
          offscreen.forEach((el) => io.observe(el));
        }

        // Safety net: si por cualquier razón un reveal queda invisible
        // 2s después de inicializar, lo forzamos visible.
        setTimeout(() => {
          document.querySelectorAll("[data-reveal]:not(.is-visible)").forEach((el) => {
            el.classList.add("is-visible");
          });
        }, 2000);

        // Light parallax (desactivado en móvil para performance/jank en iOS)
        const isMobile = window.matchMedia("(max-width: 1023px)").matches;
        const px = document.querySelectorAll<HTMLElement>("[data-parallax]");
        if (px.length && !isMobile) {
          const onScroll = () => {
            const y = window.scrollY;
            px.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax || "0.1");
              el.style.setProperty("--parallax-y", `${y * speed * -1}px`);
            });
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }
      };

      // Esperar al primer paint antes de inicializar (clave para iOS Safari).
      const boot = () => requestAnimationFrame(() => requestAnimationFrame(init));

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot, { once: true });
      } else {
        boot();
      }
      document.addEventListener("astro:page-load", boot);
    </script>
  </body>
</html>
