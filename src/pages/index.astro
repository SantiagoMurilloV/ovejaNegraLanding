---
import Base from "../layouts/Base.astro";
import TopBar from "../components/TopBar.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Philosophy from "../components/Philosophy.astro";
import Stats from "../components/Stats.astro";
import Services from "../components/Services.astro";
import Gallery from "../components/Gallery.astro";
import Team from "../components/Team.astro";
import Experience from "../components/Experience.astro";
import Testimonials from "../components/Testimonials.astro";
import Booking from "../components/Booking.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <div class="site-header sticky top-0 z-40 bg-ink border-b border-bone/8">
    <TopBar />
    <Nav />
  </div>

  <style is:global>
    /* iOS Safari: forzar layer GPU en el sticky para que NO se confunda
       con el sub-pixel scroll del viewport dinámico (Safari URL bar collapse).
       translateZ(0) + will-change garantiza que WebKit respete `position: sticky`
       en mobile incluso con `min-height: 100dvh` y secciones con overflow. */
    .site-header {
      -webkit-transform: translateZ(0);
      transform: translateZ(0);
      will-change: transform;
      /* Asegura que el header tape el contenido detrás incluso si algún hijo
         tuviera fondo transparente o backdrop-filter no aplicado. */
      isolation: isolate;
    }
  </style>
  <main>
    <Hero />
    <Marquee />
    <Philosophy />
    <Stats />
    <Services />
    <Gallery />
    <Team />
    <Experience />
    <Testimonials />
    <Booking />
    <Contact />
  </main>
  <Footer />
</Base>
