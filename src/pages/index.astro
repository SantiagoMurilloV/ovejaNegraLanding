---
import Base from "../layouts/Base.astro";
import TopBar from "../components/TopBar.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Philosophy from "../components/Philosophy.astro";
import Stats from "../components/Stats.astro";
import Services from "../components/Services.astro";
import Gallery from "../components/Gallery.astro";
import Team from "../components/Team.astro";
import Experience from "../components/Experience.astro";
import Testimonials from "../components/Testimonials.astro";
import Booking from "../components/Booking.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <!-- TECHO opaco extra: cubre por completo desde el top del viewport
       hasta el bottom del header. Es un seguro contra bugs de iOS Safari
       donde la URL bar dinámica deja ver contenido un instante. Z-index
       altísimo (50), pero pointer-events:none para que no bloquee taps. -->
  <div class="site-ceiling" aria-hidden="true"></div>

  <!-- Header con position:fixed para evitar TODOS los bugs de sticky en iOS Safari.
       El padding-top del body se calcula dinámicamente con JS midiendo el header. -->
  <div class="site-header fixed inset-x-0 top-0 z-50 bg-ink border-b border-bone/8">
    <TopBar />
    <Nav />
  </div>

  <!-- Capa frosted-glass debajo del header: el contenido scrolleando se
       difumina elegantemente al pasar por aquí. Posicionada justo abajo
       del header con altura de 56px, fade-out gradual hasta transparent. -->
  <div class="site-header-blur" aria-hidden="true"></div>

  <style is:global>
    /* Header fijo opaco. Por defecto, el body tiene un padding-top
       conservador (mobile-first ~80px) que el script de measure ajusta
       al render real. */
    body {
      padding-top: var(--site-header-h, 80px);
    }

    /* ─── CAPAS Z (de atrás hacia adelante) ─────────────────────────
       0:   <main> y secciones (contenido scrolleable, va por debajo)
       49:  .site-ceiling (techo de seguridad opaco)
       50:  .site-header (header siempre encima del techo)
       60:  .grain::after (textura sutil, encima de todo)
    */
    main {
      position: relative;
      z-index: 0;
      isolation: isolate; /* sus stacking contexts no escapan hacia arriba */
    }

    .site-ceiling {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--site-header-h, 80px);
      z-index: 49;
      background: var(--color-ink);
      pointer-events: none;
    }

    /* Fade extendido bajo el header: el contenido que pasa por debajo
       se desvanece de forma gradual y elegante, sin cortes feos.
       80px de altura con varios stops para mimic del efecto estilo
       Apple/Linear donde el contenido "se difumina" antes de desaparecer. */
    .site-header::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      height: 72px;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        var(--color-ink) 0%,
        rgba(7, 6, 10, 0.94) 18%,
        rgba(7, 6, 10, 0.78) 38%,
        rgba(7, 6, 10, 0.5)  60%,
        rgba(7, 6, 10, 0.22) 80%,
        rgba(7, 6, 10, 0)    100%
      );
      z-index: 1;
    }

    /* Blur backdrop debajo del header — efecto "frosted glass" para que
       el contenido se difumine al pasar. Solo se activa si el browser
       soporta backdrop-filter SIN mask-image (combo problemático en iOS 17+).
       Si el browser no lo aplica, el fade-gradient del ::after solo es
       suficiente como solución estética. */
    .site-header-blur {
      position: fixed;
      left: 0;
      right: 0;
      top: var(--site-header-h, 80px);
      height: 48px;
      pointer-events: none;
      z-index: 48;
    }
    @supports ((-webkit-backdrop-filter: blur(8px)) or (backdrop-filter: blur(8px))) {
      .site-header-blur {
        -webkit-backdrop-filter: blur(8px) saturate(120%);
        backdrop-filter: blur(8px) saturate(120%);
        background: linear-gradient(
          to bottom,
          rgba(7, 6, 10, 0.55) 0%,
          rgba(7, 6, 10, 0.25) 50%,
          rgba(7, 6, 10, 0)    100%
        );
      }
    }
  </style>

  <script is:inline>
    (function () {
      const apply = () => {
        const h = document.querySelector(".site-header");
        if (!h) return;
        const px = h.getBoundingClientRect().height;
        document.documentElement.style.setProperty("--site-header-h", px + "px");
      };
      apply();
      window.addEventListener("resize", apply);
      window.addEventListener("orientationchange", apply);
      // Re-medir tras cargar fonts (cambian el alto del Nav)
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(apply);
      }
      document.addEventListener("astro:page-load", apply);
    })();
  </script>

  <main>
    <Hero />
    <Marquee />
    <Philosophy />
    <Stats />
    <Services />
    <Gallery />
    <Team />
    <Experience />
    <Testimonials />
    <Booking />
    <Contact />
  </main>
  <Footer />
</Base>
