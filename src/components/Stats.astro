---
import { site } from "../data/site";
---

<section class="relative py-20 lg:py-28 border-y border-bone/5 bg-coal/30">
  <div class="container-screen grid grid-cols-2 lg:grid-cols-4">
    {site.stats.map((s, i) => (
      <div
        class={`flex flex-col gap-3 px-6 lg:px-10 py-4 lg:py-6 ${i > 0 ? "lg:border-l border-bone/10" : ""} ${i === 2 ? "border-t lg:border-t-0 border-bone/10" : ""} ${i === 3 ? "border-t lg:border-t-0 border-bone/10" : ""}`}
        data-reveal
        style={`--reveal-delay: ${i * 60}ms`}
      >
        <p class="font-display text-5xl lg:text-7xl text-gradient-gold leading-none">{s.value}</p>
        <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-fog">{s.label}</p>
      </div>
    ))}
  </div>
</section>
