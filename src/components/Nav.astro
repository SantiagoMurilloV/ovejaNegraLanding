---
import Logo from "./Logo.astro";
import { site } from "../data/site";

const links = [
  { href: "#filosofia", label: "Filosofía" },
  { href: "#servicios", label: "Servicios" },
  { href: "#equipo", label: "Equipo" },
  { href: "#experiencia", label: "Experiencia" },
  { href: "#contacto", label: "Contacto" },
];
---

<header
  id="site-nav"
  class="sticky top-0 z-40 border-b border-bone/5 bg-ink supports-[backdrop-filter]:bg-ink/80 backdrop-blur-xl transition-all duration-500"
>
  <div class="container-screen flex items-center justify-between py-4">
    <Logo class="text-bone" />

    <nav aria-label="Principal" class="hidden lg:flex items-center gap-8 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class="relative text-bone/70 hover:text-bone transition-colors duration-300 nav-link"
        >
          <span>{l.label}</span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={site.bookingUrl}
        target="_blank"
        rel="noopener"
        class="btn btn-primary !hidden lg:!inline-flex"
      >
        Reservar
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <button
        id="menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full ring-bone hover:bg-bone/5 transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h10" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Side drawer (FUERA del header para no heredar stacking context) -->
<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 z-[100] is-closed"
  role="dialog"
  aria-modal="true"
  aria-label="Menú principal"
>
  <!-- Backdrop oscuro clickeable -->
  <div
    id="drawer-backdrop"
    class="drawer-bg absolute inset-0 bg-ink/70 backdrop-blur-sm"
    aria-hidden="true"
  ></div>

  <!-- Panel lateral -->
  <aside
    class="drawer-panel absolute top-0 right-0 h-full w-[58vw] max-w-[260px] bg-coal border-l border-bone/10 shadow-[0_0_60px_-10px_rgba(0,0,0,0.8)] flex flex-col overflow-hidden"
  >
    <!-- Spotlight decorativo dentro del panel -->
    <div aria-hidden="true" class="pointer-events-none absolute -top-1/3 -right-1/3 h-[50vh] w-[50vh] rounded-full bg-gold/8 blur-3xl"></div>

    <!-- Header del drawer -->
    <div class="relative flex items-center justify-between px-4 py-4 border-b border-bone/8">
      <span class="font-mono text-[10px] tracking-[0.32em] uppercase text-fog">Menú</span>
      <button
        id="menu-close"
        aria-label="Cerrar menú"
        class="inline-flex h-8 w-8 items-center justify-center rounded-full ring-bone hover:bg-bone/5 transition-colors"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <!-- Nav -->
    <nav class="relative flex-1 flex flex-col justify-between overflow-y-auto px-4 py-6">
      <!-- Links principales -->
      <ul class="flex flex-col">
        {links.map((l, i) => (
          <li style={`--mlink-delay: ${120 + i * 50}ms`}>
            <a
              href={l.href}
              data-mlink
              class="drawer-link group flex items-center justify-between font-display text-bone/90 hover:text-gold transition-colors py-3 text-[15px] tracking-tight"
            >
              <span class="flex items-center gap-2.5">
                <span class="font-mono text-[8px] tracking-[0.28em] uppercase text-fog group-hover:text-gold/80 transition-colors w-4">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span>{l.label}</span>
              </span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" class="opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition-all">
                <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <!-- Footer minimal -->
      <div class="pt-6 border-t border-bone/8 flex flex-col gap-1.5 font-mono text-[9px] tracking-[0.22em] uppercase text-fog">
        <a href={site.whatsappLink} target="_blank" rel="noopener" class="hover:text-bone transition-colors">
          WhatsApp
        </a>
        <a href={site.instagram} target="_blank" rel="noopener" class="hover:text-bone transition-colors">
          Instagram
        </a>
      </div>
    </nav>
  </aside>
</div>

<script>
  const init = () => {
    const nav = document.getElementById("site-nav");
    const menu = document.getElementById("mobile-menu");
    const toggle = document.getElementById("menu-toggle");
    const close = document.getElementById("menu-close");
    const mlinks = document.querySelectorAll("[data-mlink]");

    const lockScroll = () => {
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
    };
    const unlockScroll = () => {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    };

    const openMenu = () => {
      if (!menu) return;
      menu.classList.remove("is-closed");
      menu.classList.add("is-open");
      toggle?.setAttribute("aria-expanded", "true");
      lockScroll();
    };
    const closeMenu = () => {
      if (!menu) return;
      menu.classList.remove("is-open");
      menu.classList.add("is-closed");
      toggle?.setAttribute("aria-expanded", "false");
      unlockScroll();
    };

    const backdrop = document.getElementById("drawer-backdrop");

    toggle?.addEventListener("click", openMenu);
    close?.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);
    mlinks.forEach((a) => a.addEventListener("click", closeMenu));

    // ESC cierra el menú
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu?.classList.contains("is-open")) closeMenu();
    });

    // Scroll-shadow del header
    const onScroll = () => {
      if (!nav) return;
      if (window.scrollY > 8) nav.classList.add("is-scrolled");
      else nav.classList.remove("is-scrolled");
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  };

  document.addEventListener("astro:page-load", init);
  init();
</script>

<style>
  /* Header scrolled — background sólido por defecto, semitransparente solo si el navegador soporta backdrop-filter (iOS Safari + overflow-x: hidden a veces lo rompe; mejor sólido que ilegible). */
  #site-nav.is-scrolled {
    background: var(--color-ink);
    box-shadow: 0 10px 30px -20px rgba(0, 0, 0, 0.6);
  }
  @supports ((-webkit-backdrop-filter: blur(8px)) or (backdrop-filter: blur(8px))) {
    #site-nav.is-scrolled {
      background: color-mix(in oklab, var(--color-ink) 90%, transparent);
    }
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 1px;
    width: 0;
    background: var(--color-gold);
    transition: width 320ms var(--ease-out-expo);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* ─── Drawer states (slide-in lateral) ─────────────────────────
     Curva: cubic-bezier(0.32, 0.72, 0, 1) — natural en ambos extremos
     (la misma que usa iOS para los modales y sheets).
     Visibility se aplica con transition-delay igual a la animación,
     para que el panel termine de salir antes de ocultarse. */
  :root {
    --drawer-ease: cubic-bezier(0.32, 0.72, 0, 1);
    --drawer-duration: 480ms;
  }

  #mobile-menu {
    transition: visibility 0s linear var(--drawer-duration);
  }
  #mobile-menu.is-closed {
    pointer-events: none;
    visibility: hidden;
  }
  #mobile-menu.is-open {
    visibility: visible;
    transition-delay: 0s;
  }

  /* Backdrop fade — sincronizado con la duración del panel */
  .drawer-bg {
    transition: opacity var(--drawer-duration) var(--drawer-ease);
    will-change: opacity;
  }
  #mobile-menu.is-closed .drawer-bg {
    opacity: 0;
  }
  #mobile-menu.is-open .drawer-bg {
    opacity: 1;
  }

  /* Panel slide */
  .drawer-panel {
    transition: transform var(--drawer-duration) var(--drawer-ease);
    will-change: transform;
  }
  #mobile-menu.is-closed .drawer-panel {
    transform: translateX(100%);
  }
  #mobile-menu.is-open .drawer-panel {
    transform: translateX(0);
  }

  /* Links: solo cascada al abrir. Al cerrar, salen junto con el panel. */
  .drawer-link {
    transition:
      opacity 240ms ease-out,
      transform 240ms ease-out,
      color 200ms;
  }
  #mobile-menu.is-closed .drawer-link {
    opacity: 0;
    transform: translateX(16px);
  }
  #mobile-menu.is-open .drawer-link {
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 520ms var(--drawer-ease) var(--mlink-delay),
      transform 600ms var(--drawer-ease) var(--mlink-delay),
      color 200ms;
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-menu, .drawer-bg, .drawer-panel, .drawer-link {
      transition: none !important;
    }
  }
</style>
