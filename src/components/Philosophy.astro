---
import { philosophy } from "../data/site";
---

<section id="filosofia" class="relative py-28 lg:py-44">
  <div class="container-screen grid lg:grid-cols-12 gap-12 lg:gap-16">
    <div class="lg:col-span-5 lg:sticky lg:top-32 self-start" data-reveal>
      <p class="eyebrow mb-6">— Nuestra filosofía</p>
      <h2 class="h-section text-bone">
        El corte es la <em class="font-light text-gradient-gold not-italic">excusa</em>.
        El ritual es lo que te llevas.
      </h2>
      <p class="mt-8 text-fog text-lg leading-relaxed max-w-md">
        Aquí no hay filas, ni música a todo volumen, ni prisa. Una silla, una cita, un cliente.
        Tiempo real para hacer las cosas bien.
      </p>
    </div>

    <ol class="lg:col-span-7 grid gap-px bg-bone/5">
      {philosophy.map((p, i) => (
        <li
          class="bg-ink p-8 lg:p-12 grid grid-cols-[auto_1fr] gap-6 lg:gap-10 items-start group hover:bg-coal transition-colors duration-500"
          data-reveal
          style={`--reveal-delay: ${i * 80}ms`}
        >
          <span class="font-mono text-xs text-gold tracking-[0.22em]">{p.n}</span>
          <div>
            <h3 class="font-display text-3xl lg:text-4xl text-bone leading-none group-hover:text-gradient-gold transition-all duration-500">
              {p.title}
            </h3>
            <p class="mt-4 text-fog leading-relaxed max-w-md">{p.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
