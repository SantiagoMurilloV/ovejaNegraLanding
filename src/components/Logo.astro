---
interface Props {
  class?: string;
  size?: number;
  showText?: boolean;
}
const { class: className = "", size = 44, showText = true } = Astro.props;
const ratio = 280 / 260; // viewBox is 260×280
---

<a href="/" aria-label="Oveja Negra Gentleman Studio — Inicio" class={`group inline-flex items-center gap-3.5 ${className}`}>
  <!--
    Emblema oficial vectorizado — estilo nórdico/vikingo:
    • Haz central de 3 navajas que se afilan en punta arriba y abajo (fill).
    • Dos scrolls superiores cuadrados con espiral interior tipo greca.
    • Dos pies inferiores en escuadra simétricos.
  -->
  <svg
    viewBox="0 0 260 280"
    width={size}
    height={Math.round(size * ratio)}
    xmlns="http://www.w3.org/2000/svg"
    class="transition-transform duration-700 ease-[var(--ease-out-expo)] group-hover:-translate-y-0.5"
    aria-hidden="true"
  >
    <!-- Central blade cluster -->
    <g fill="currentColor" stroke="none">
      <path d="M 130 26 L 134 150 L 130 254 L 126 150 Z" />
      <path d="M 121 48 L 125 150 L 121 232 L 117 150 Z" />
      <path d="M 139 48 L 143 150 L 139 232 L 135 150 Z" />
    </g>

    <!-- Top-left scroll (square greca with inner spiral) -->
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="3">
      <path d="M 130 56 L 100 56 L 100 38 L 28 38 L 28 112 L 90 112 L 90 56" />
      <path d="M 48 56 L 48 92 L 78 92 L 78 70 L 60 70 L 60 84" />
    </g>

    <!-- Top-right scroll (mirror) -->
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="3">
      <path d="M 130 56 L 160 56 L 160 38 L 232 38 L 232 112 L 170 112 L 170 56" />
      <path d="M 212 56 L 212 92 L 182 92 L 182 70 L 200 70 L 200 84" />
    </g>

    <!-- Bottom-left foot -->
    <g fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="3">
      <path d="M 121 232 L 96 232 L 96 256 L 70 256 L 70 240 L 88 240 L 88 250" />
    </g>

    <!-- Bottom-right foot -->
    <g fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="3">
      <path d="M 139 232 L 164 232 L 164 256 L 190 256 L 190 240 L 172 240 L 172 250" />
    </g>
  </svg>

  {showText && (
    <span class="flex flex-col leading-none">
      <span class="font-display text-[15px] sm:text-base tracking-[0.02em]">Oveja Negra</span>
      <span class="hidden sm:inline font-mono text-[9px] tracking-[0.34em] uppercase text-fog mt-1">Gentleman Studio</span>
    </span>
  )}
</a>
