---
import { amenities, site } from "../data/site";

const icon: Record<string, string> = {
  wind: `<path d="M3 8h12a3 3 0 1 0-3-3M3 12h18M3 16h15a3 3 0 1 1-3 3"/>`,
  parking: `<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 8h4a3 3 0 0 1 0 6H9V8zm0 6v4"/>`,
  beer: `<path d="M9 6h7v12a2 2 0 0 1-2 2H11a2 2 0 0 1-2-2V6zm7 3h2a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-2M9 4c.5-1 1.5-1 2 0s1.5 1 2 0 1.5-1 2 0"/>`,
  coffee: `<path d="M4 8h13v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V8zm13 1h2a2 2 0 0 1 0 4h-2M8 4c.5-1 0-2 0-3M12 4c.5-1 0-2 0-3"/>`,
  spray: `<path d="M9 3h6v4H9zM10 7v3M14 7v3M7 12h10v9H7zM10 16h4"/>`,
  vinyl: `<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="0.6" fill="currentColor"/>`,
  lock: `<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>`,
  spark: `<path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z"/>`,
  sun: `<circle cx="12" cy="12" r="3.6"/><path d="M12 2.5v2.5M12 19v2.5M2.5 12H5M19 12h2.5M5 5l1.8 1.8M17.2 17.2L19 19M19 5l-1.8 1.8M6.8 17.2L5 19"/>`,
};
---

<section id="experiencia" class="relative py-28 lg:py-44">
  <div class="container-screen grid lg:grid-cols-12 gap-12">
    <header class="lg:col-span-5 lg:sticky lg:top-32 self-start" data-reveal>
      <p class="eyebrow mb-4">— Tu experiencia</p>
      <h2 class="h-section text-bone">
        Más que un<br /> corte. Un<br />
        <em class="font-light not-italic text-gradient-gold">refugio</em>.
      </h2>
      <p class="mt-8 text-fog text-lg max-w-md leading-relaxed">
        Aire acondicionado, parqueadero privado, productos premium, café de origen, cerveza de barril
        y la silla mejor cuidada de la ciudad milagro.
      </p>
      <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-primary mt-10 inline-flex">
        Vivir la experiencia
      </a>
    </header>

    <ul class="lg:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-px bg-bone/5 ring-bone rounded-3xl overflow-hidden">
      {amenities.map((a, i) => (
        <li
          class="bg-ink p-7 lg:p-9 group hover:bg-coal transition-colors duration-500 flex flex-col gap-6"
          data-reveal
          style={`--reveal-delay: ${i * 50}ms`}
        >
          <span class="inline-flex items-center justify-center h-12 w-12 rounded-full ring-bone text-gold group-hover:bg-gold group-hover:text-ink transition-colors duration-500">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon[a.icon]}></svg>
          </span>
          <span class="font-display text-xl text-bone">{a.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
