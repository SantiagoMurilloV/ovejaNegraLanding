---
import Logo from "./Logo.astro";
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-bone/5 bg-ink">
  <!-- ═══════════════════════════════════════════
       MOBILE FOOTER (compacto, < lg)
       Solo logo + 3 enlaces sociales + copyright.
       Toda la info de contacto ya está en la sección
       #contacto justo arriba — no se duplica.
       ═══════════════════════════════════════════ -->
  <div class="lg:hidden container-screen py-10">
    <div class="flex items-center justify-between gap-6">
      <Logo class="text-bone" size={32} showText={false} />
      <div class="flex items-center gap-1">
        <a
          href={site.whatsappLink}
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full text-bone/70 hover:text-gold hover:bg-bone/5 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.6 6.3A8 8 0 0 0 4.3 16l-1.1 4 4.1-1.1a8 8 0 0 0 12-7 8 8 0 0 0-1.7-5.6Zm-5.6 12.3a6.6 6.6 0 0 1-3.4-1l-.2-.1-2.4.7.6-2.3-.1-.3a6.6 6.6 0 0 1 5.5-10.1 6.6 6.6 0 0 1 6.6 6.6 6.6 6.6 0 0 1-6.6 6.5Zm3.6-4.9c-.2-.1-1.2-.6-1.4-.6-.2-.1-.3-.1-.4.1-.1.2-.4.5-.5.6-.1.1-.2.1-.3 0-.2-.1-.8-.3-1.5-.9a5.5 5.5 0 0 1-1-1.3c-.1-.2 0-.3.1-.4l.3-.3.2-.3v-.3l-.6-1.3c-.1-.3-.3-.3-.4-.3h-.4a.7.7 0 0 0-.5.2c-.2.2-.7.6-.7 1.6 0 1 .7 1.9.8 2 .1.2 1.5 2.3 3.6 3.2.5.2 1 .3 1.3.4.5.2 1 .1 1.4.1.4-.1 1.2-.5 1.4-1 .2-.5.2-.9.1-1l-.4-.2Z"/>
          </svg>
        </a>
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full text-bone/70 hover:text-gold hover:bg-bone/5 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href={`mailto:${site.email}`}
          aria-label="Email"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full text-bone/70 hover:text-gold hover:bg-bone/5 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" />
          </svg>
        </a>
      </div>
    </div>

    <p class="mt-8 font-mono text-[9px] tracking-[0.22em] uppercase text-fog/70 text-center">
      © {year} · Oveja Negra · Armenia, Q
    </p>
  </div>

  <!-- ═══════════════════════════════════════════
       DESKTOP FOOTER (denso, lg+)
       Watermark + 3 columnas + créditos.
       ═══════════════════════════════════════════ -->
  <div class="hidden lg:block">
    <!-- Watermark -->
    <div aria-hidden="true" class="select-none pointer-events-none container-screen pt-20">
      <p class="font-display text-[20vw] leading-[0.8] text-bone/[0.04] tracking-[-0.04em] whitespace-nowrap">
        OvejaNegra.
      </p>
    </div>

    <div class="container-screen relative pb-12 -mt-16">
      <div class="grid grid-cols-12 gap-10 pb-12 border-b border-bone/5">
        <div class="col-span-5">
          <Logo class="text-bone" />
          <p class="mt-6 max-w-sm text-fog leading-relaxed">{site.shortDesc}</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-primary">Reservar</a>
            <a href={site.whatsappLink} target="_blank" rel="noopener" class="btn btn-ghost">WhatsApp</a>
          </div>
        </div>

        <div class="col-span-3">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-fog mb-4">Estudio</p>
          <ul class="space-y-3 text-bone/85">
            <li><a href="#filosofia" class="hover:text-gold transition-colors">Filosofía</a></li>
            <li><a href="#servicios" class="hover:text-gold transition-colors">Servicios</a></li>
            <li><a href="#equipo" class="hover:text-gold transition-colors">Equipo</a></li>
            <li><a href="#experiencia" class="hover:text-gold transition-colors">Experiencia</a></li>
            <li><a href="#contacto" class="hover:text-gold transition-colors">Contacto</a></li>
          </ul>
        </div>

        <div class="col-span-4">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-fog mb-4">Encuéntranos</p>
          <p class="text-bone/85 leading-relaxed">{site.address}</p>
          <p class="mt-4 font-mono text-sm tracking-wider text-fog">{site.whatsapp}</p>
          <a href={site.instagram} target="_blank" rel="noopener" class="mt-2 inline-block text-bone/85 hover:text-gold transition-colors">@ovejanegra.studio_94</a>
        </div>
      </div>

      <div class="pt-6 flex flex-wrap items-center justify-between gap-4 font-mono text-[11px] tracking-[0.22em] uppercase text-fog">
        <p>© {year} Oveja Negra Studio · Todos los derechos reservados</p>
        <p>Diseñado con cuidado en Armenia · Quindío</p>
      </div>
    </div>
  </div>
</footer>
