---
import { testimonials } from "../data/site";
---

<section class="relative py-28 lg:py-44">
  <div class="container-screen">
    <header class="grid lg:grid-cols-12 gap-10 mb-14" data-reveal>
      <p class="eyebrow lg:col-span-3">— Lo que cuentan</p>
      <h2 class="h-section text-bone lg:col-span-7">
        Voces de la <em class="font-light not-italic text-gradient-gold">silla</em>.
      </h2>
    </header>

    <div class="grid md:grid-cols-3 gap-4 lg:gap-6">
      {testimonials.map((t, i) => (
        <figure
          class="card p-8 lg:p-10 relative overflow-hidden group hover:bg-soot/60 transition-colors"
          data-reveal
          style={`--reveal-delay: ${i * 80}ms`}
        >
          <span aria-hidden="true" class="absolute -top-4 left-6 font-display text-[8rem] leading-none text-gold/15 select-none">"</span>
          <blockquote class="relative font-display text-2xl lg:text-3xl leading-snug text-bone text-pretty">
            {t.quote}
          </blockquote>
          <figcaption class="relative mt-8 pt-6 border-t border-bone/5">
            <p class="font-display text-lg text-bone">{t.author}</p>
            <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-fog mt-1">{t.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
